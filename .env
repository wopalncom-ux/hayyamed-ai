# ============================================
# HAYYAMED AI — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================

# ─── APP ─────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://app.hayyamed.ai
NEXT_PUBLIC_API_URL=https://api.hayyamed.ai/api/v1
NEXT_PUBLIC_WS_URL=wss://api.hayyamed.ai

# ─── DATABASE ────────────────────────────────
DATABASE_URL=postgresql://hayyamed:YOUR_DB_PASSWORD@postgres:5432/hayyamed
DB_USER=hayyamed
DB_PASSWORD=YOUR_DB_PASSWORD

# ─── REDIS ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ─── JWT ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-jwt-key-min-32-chars

# ─── OPENAI ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── WHATSAPP BUSINESS API ───────────────────
WHATSAPP_ACCESS_TOKEN=EAAxxxx...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210
WHATSAPP_WEBHOOK_TOKEN=your-webhook-verify-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ─── INSTAGRAM / FACEBOOK ────────────────────
INSTAGRAM_ACCESS_TOKEN=IGQVxx...
FACEBOOK_PAGE_ACCESS_TOKEN=EAAxx...
FACEBOOK_PAGE_ID=your-page-id

# ─── TELEGRAM ────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCxx...

# ─── EMAIL (SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@hayyamed.ai
SMTP_PASS=your-email-password

# ─── BILLING (STRIPE) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── GOOGLE OAUTH ────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── NEXTAUTH ────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://app.hayyamed.ai

# ─── STORAGE (AWS S3 or Cloudflare R2) ───────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=me-south-1
AWS_S3_BUCKET=hayyamed-media

# ─── SMS (OPTIONAL) ──────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+97412345678
